<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EmulatorAVR.Avalonia.Views.MainWindow"
        Title="emulatorAVR — ATmega328P State Viewer"
        Width="860" Height="680"
        Background="{StaticResource AppBackground}"
        Foreground="{StaticResource PrimaryText}">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="12">

      <!-- Header -->
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding AppTitle}" Classes="title" />
        <TextBlock Text="{Binding AppSubtitle}" Classes="subtitle" />
      </StackPanel>

      <!-- CPU Summary Cards -->
      <WrapPanel>
        <Border Classes="summaryCard" Margin="0,0,10,0">
          <StackPanel Spacing="4">
            <TextBlock Text="Program Counter" Classes="label" />
            <TextBlock Text="{Binding PcText}" Classes="monoValue" FontSize="20" FontWeight="Bold" />
          </StackPanel>
        </Border>
        <Border Classes="summaryCard" Margin="0,0,10,0">
          <StackPanel Spacing="4">
            <TextBlock Text="Cycle Count" Classes="label" />
            <TextBlock Text="{Binding CycleCountText}" Classes="monoValue" FontSize="20" FontWeight="Bold" />
          </StackPanel>
        </Border>
        <Border Classes="summaryCard">
          <StackPanel Spacing="4">
            <TextBlock Text="SREG Raw" Classes="label" />
            <TextBlock Text="{Binding SregRawText}" Classes="monoValue" FontSize="20" FontWeight="Bold" />
          </StackPanel>
        </Border>
      </WrapPanel>

      <!-- SREG Flags -->
      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="SREG Flags" Classes="sectionHeader" />
          <ItemsControl ItemsSource="{Binding Flags}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel>
                  <Border Classes="flagActive" IsVisible="{Binding IsActive}" Margin="0,0,6,4">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" />
                  </Border>
                  <Border Classes="flagInactive" IsVisible="{Binding IsInactive}" Margin="0,0,0,4">
                    <TextBlock Text="{Binding Name}" FontSize="13" />
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Registers -->
      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Registers (R0..R31)" Classes="sectionHeader" />
          <ItemsControl ItemsSource="{Binding Registers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource CardBorder}" CornerRadius="4" Padding="8,4" Margin="0,0,6,4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" Classes="label" Width="24" />
                    <TextBlock Text="{Binding ValueText}" Classes="monoValue" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Ports -->
      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Port Registers" Classes="sectionHeader" />
          <TextBlock Text="{Binding PortStatusText}" Foreground="{StaticResource MutedText}" FontStyle="Italic" FontSize="11" />
          <ItemsControl ItemsSource="{Binding Ports}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource CardBorder}" CornerRadius="4" Padding="8,4" Margin="0,0,6,4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" Classes="label" Width="48" />
                    <TextBlock Text="{Binding ValueText}" Classes="monoValue" />
                    <TextBlock Text="{Binding AddressText, StringFormat='({0})'}" Foreground="{StaticResource MutedText}" FontSize="11" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Arduino Digital Pin Map -->
      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="Arduino Digital Pin Map" Classes="sectionHeader" />
          <TextBlock Text="D0..D13 — static/demo mapping, no live execution" Foreground="{StaticResource MutedText}" FontStyle="Italic" FontSize="11" />
          <ItemsControl ItemsSource="{Binding Pins}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="pinMappingCard" Margin="0,0,6,4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding PinLabel}" Classes="pinLabel" />
                    <TextBlock Text="{Binding PortName}" Classes="label" />
                    <TextBlock Text="{Binding BitLabel}" Foreground="{StaticResource MutedText}" FontSize="11" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Window>
