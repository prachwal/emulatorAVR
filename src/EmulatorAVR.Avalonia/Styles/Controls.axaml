<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Section card -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource CardBackground}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <!-- Section header text -->
  <Style Selector="TextBlock.sectionHeader">
    <Setter Property="Foreground" Value="{StaticResource SectionAccent}" />
    <Setter Property="FontSize" Value="{StaticResource SectionHeaderSize}" />
    <Setter Property="FontWeight" Value="{StaticResource SectionHeaderWeight}" />
  </Style>

  <!-- Label text -->
  <Style Selector="TextBlock.label">
    <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
    <Setter Property="FontSize" Value="{StaticResource LabelSize}" />
    <Setter Property="FontWeight" Value="{StaticResource LabelWeight}" />
  </Style>

  <!-- Value text -->
  <Style Selector="TextBlock.value">
    <Setter Property="Foreground" Value="{StaticResource ValueText}" />
    <Setter Property="FontSize" Value="{StaticResource ValueSize}" />
    <Setter Property="FontWeight" Value="{StaticResource ValueWeight}" />
  </Style>

  <!-- Card value text (PC / cycle count) -->
  <Style Selector="TextBlock.cardValue">
    <Setter Property="Foreground" Value="{StaticResource ValueText}" />
    <Setter Property="FontSize" Value="{StaticResource CardValueSize}" />
    <Setter Property="FontWeight" Value="{StaticResource CardValueWeight}" />
    <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
  </Style>

  <!-- Active flag chip -->
  <Style Selector="Border.flagActive">
    <Setter Property="Background" Value="{StaticResource ActiveFlagBackground}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="6,2" />
  </Style>
  <Style Selector="Border.flagActive TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ActiveFlagText}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Inactive flag chip -->
  <Style Selector="Border.flagInactive">
    <Setter Property="Background" Value="{StaticResource InactiveFlagBackground}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="6,2" />
  </Style>
  <Style Selector="Border.flagInactive TextBlock">
    <Setter Property="Foreground" Value="{StaticResource InactiveFlagText}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Title text -->
  <Style Selector="TextBlock.title">
    <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
    <Setter Property="FontSize" Value="{StaticResource TitleSize}" />
    <Setter Property="FontWeight" Value="{StaticResource TitleWeight}" />
  </Style>

  <!-- Subtitle text -->
  <Style Selector="TextBlock.subtitle">
    <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
    <Setter Property="FontSize" Value="{StaticResource SubtitleSize}" />
    <Setter Property="FontWeight" Value="{StaticResource SubtitleWeight}" />
  </Style>

  <!-- Monospace value text -->
  <Style Selector="TextBlock.monoValue">
    <Setter Property="Foreground" Value="{StaticResource ValueText}" />
    <Setter Property="FontSize" Value="{StaticResource ValueSize}" />
    <Setter Property="FontWeight" Value="{StaticResource ValueWeight}" />
    <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
  </Style>

  <!-- Summary card (smaller variant for individual CPU values) -->
  <Style Selector="Border.summaryCard">
    <Setter Property="Background" Value="{StaticResource CardBackground}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="MinWidth" Value="120" />
  </Style>

  <!-- Pin mapping card -->
  <Style Selector="Border.pinMappingCard">
    <Setter Property="Background" Value="{StaticResource CardBackground}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,4" />
  </Style>

  <!-- Pin label text -->
  <Style Selector="TextBlock.pinLabel">
    <Setter Property="Foreground" Value="{StaticResource SectionAccent}" />
    <Setter Property="FontSize" Value="{StaticResource ValueSize}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <!-- Small cell for register items -->
  <Style Selector="Border.registerCell">
    <Setter Property="Background" Value="{StaticResource CardBorder}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="Margin" Value="0,0,6,4" />
  </Style>

  <!-- Small cell for port items -->
  <Style Selector="Border.portCell">
    <Setter Property="Background" Value="{StaticResource CardBorder}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="Margin" Value="0,0,6,4" />
  </Style>

  <!-- Status text (italic muted description lines) -->
  <Style Selector="TextBlock.statusText">
    <Setter Property="Foreground" Value="{StaticResource MutedText}" />
    <Setter Property="FontStyle" Value="Italic" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <!-- Flag label text (inside active/inactive chips) -->
  <Style Selector="TextBlock.flagLabel">
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- Register name label -->
  <Style Selector="TextBlock.registerLabel">
    <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
    <Setter Property="FontSize" Value="{StaticResource LabelSize}" />
    <Setter Property="FontWeight" Value="{StaticResource LabelWeight}" />
    <Setter Property="Width" Value="24" />
  </Style>

  <!-- Port name label -->
  <Style Selector="TextBlock.portLabel">
    <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
    <Setter Property="FontSize" Value="{StaticResource LabelSize}" />
    <Setter Property="FontWeight" Value="{StaticResource LabelWeight}" />
    <Setter Property="Width" Value="48" />
  </Style>

  <!-- Muted address text -->
  <Style Selector="TextBlock.addressText">
    <Setter Property="Foreground" Value="{StaticResource MutedText}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <!-- Muted bit label text -->
  <Style Selector="TextBlock.bitLabel">
    <Setter Property="Foreground" Value="{StaticResource MutedText}" />
    <Setter Property="FontSize" Value="11" />
  </Style>
</Styles>
